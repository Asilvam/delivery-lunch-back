# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Optional database name used by Mongoose
MONGODB_DB_NAME=delivery_lunch

# API port
PORT=3500

# JWT
JWT_SECRET=cambia_este_secret_en_produccion
JWT_EXPIRES_IN=7d

# Admin credentials (ADMIN_PASSWORD_HASH = bcrypt hash del password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# WhatsApp (Callmebot)
# Activar enviando "I allow callmebot to send me messages" al +34 644 45 79 90
WHATSAPP_NOTIFY_PHONE=56981914285
CALLMEBOT_API_KEY=123456
